\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Multi-goal replanning trajectories.} Each panel shows the maze with cluster coloring (faded) and overlaid goal-reaching trajectories (colored paths with numbered goal stars). The agent learns the environment once, then navigates to a sequence of goals without relearning. (a) UMaze with 5 goals spanning all rooms. (b) Medium with 5 goals at corners and center. (c) Large with 6 goals spanning the full maze.}}{12}{figure.caption.18}\protected@file@percent }
\newlabel{fig:replan_all}{{5}{12}{\textbf {Multi-goal replanning trajectories.} Each panel shows the maze with cluster coloring (faded) and overlaid goal-reaching trajectories (colored paths with numbered goal stars). The agent learns the environment once, then navigates to a sequence of goals without relearning. (a) UMaze with 5 goals spanning all rooms. (b) Medium with 5 goals at corners and center. (c) Large with 6 goals spanning the full maze}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Macro-state clusters with all goal locations.} Numbered stars indicate the sequential goals used in replanning experiments. Clusters correspond to spatially coherent maze regions (rooms, corridor segments).}}{12}{figure.caption.19}\protected@file@percent }
\newlabel{fig:replan_clusters}{{6}{12}{\textbf {Macro-state clusters with all goal locations.} Numbered stars indicate the sequential goals used in replanning experiments. Clusters correspond to spatially coherent maze regions (rooms, corridor segments)}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Per-goal step comparison: Hierarchy vs.\ Flat.} Bar charts showing the number of physics steps to reach each sequential goal. Red crosses indicate failure to reach the goal within the step limit. The hierarchical agent (blue) generally reaches goals faster than the flat agent (orange), with greater advantage on longer paths.}}{13}{figure.caption.20}\protected@file@percent }
\newlabel{fig:replan_steps}{{7}{13}{\textbf {Per-goal step comparison: Hierarchy vs.\ Flat.} Bar charts showing the number of physics steps to reach each sequential goal. Red crosses indicate failure to reach the goal within the step limit. The hierarchical agent (blue) generally reaches goals faster than the flat agent (orange), with greater advantage on longer paths}{figure.caption.20}{}}
